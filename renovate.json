{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "rangeStrategy": "replace",
  "packageRules": [
    {
      "matchPackagePatterns": ["^astro$", "^@astrojs/"],
      "groupName": "Astro"
    },
    {
      "matchPackagePatterns": ["^msw$", "^@mswjs/"],
      "groupName": "MSW"
    }
  ]
}
